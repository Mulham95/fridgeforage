# Copy to .env and fill in. Expo exposes EXPO_PUBLIC_* vars to the app at build time.

# URL of your deployed Cloudflare Worker (see proxy/worker.js).
# Without this, AI features (receipt scan, recipe generation) fail gracefully;
# barcode lookup and the local FoodKeeper database still work fully offline.
EXPO_PUBLIC_FRIDGEFORAGE_API=https://fridgeforage-ai.YOUR-SUBDOMAIN.workers.dev

# MOBILE BUILDS ONLY (EAS or Android Studio): must match APP_SHARED_SECRET set
# on the Worker. Leave this UNSET for the public web build — the web app passes
# the proxy's auth via its Origin (CORS allow-list), not this secret. Putting
# the secret in a public web bundle would defeat its purpose.
#
# Workflow:
#   1. proxy/   → npx wrangler secret put APP_SHARED_SECRET   (paste any random string)
#   2. .env     → EXPO_PUBLIC_APP_SECRET=<same string>  (only when building APK/IPA)
#   3. before `npm run deploy:web`, REMOVE / comment out EXPO_PUBLIC_APP_SECRET
# EXPO_PUBLIC_APP_SECRET=
